{
  "additive_delta_tensors": 1,
  "additive_delta_values": 2,
  "base": "TMP/base",
  "copied_metadata": [
    "config.json"
  ],
  "copied_nonfloating_tensors": 1,
  "default_weights": {
    "code": 0.0,
    "general": 0.0
  },
  "dry_run": false,
  "floating_tensors": 6,
  "freeze_regex": [],
  "freeze_router": true,
  "frozen_tensors": 2,
  "output_dtype": "base",
  "packed_expert_rule_csv": [],
