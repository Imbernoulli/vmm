    "rule_count": 0,
    "slice_count": 0,
    "tensor_count": 0,
    "tensors": []
  },
  "rule_counts": {
    "default": 1,
    "freeze_router": 2,
    "tensor_rule:.*experts\\.0\\..*": 1,
    "tensor_rule:.*experts\\.1\\..*": 1,
    "tensor_rule:.*self_attn.*": 1
  },
  "same_shape_constraint": "All output tensors keep base tensor names and shapes; metadata is copied from base when available.",
  "schema_version": 1,
  "shards": [
    {
      "shard": "model.safetensors",
      "tensors": 7
    }
  ],
  "source_summaries": {
    "code": {
      "aliased_tensors": 2,
      "dtype_mismatches": 0,
      "extra_tensors": 0,
      "missing_tensors": 0,
      "root": "TMP/code",
      "shape_mismatches": 0,
      "tensors": 7
    },
    "general": {
      "aliased_tensors": 0,
      "dtype_mismatches": 0,
      "extra_tensors": 0,
      "missing_tensors": 0,
      "root": "TMP/general",
      "shape_mismatches": 0,
      "tensors": 7
    }
  },
  "sources": {
    "code": "TMP/code",
    "general": "TMP/general"
  },
  "tensor_add_csv": [
    "TMP/router_bias_delta.csv"
  ],
  "tensor_add_delta_summary": {
    "abs_delta_sum": 0.5,
    "delta_count": 2,
    "max_abs_delta": 0.375,
    "tensor_count": 1,
    "tensors": [
      {
        "abs_delta_sum": 0.5,
