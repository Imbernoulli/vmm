        "max_abs_delta": 0.375,
        "shape": [
          2
        ],
        "tensor": "model.layers.0.router.bias"
      }
    ]
  },
  "tensor_alias_rules": [
    {
      "pattern": "(^|.*\\.)experts\\.0\\.",
      "replacement": "\\1experts.1.",
      "source": "code"
    },
    {
      "pattern": "(^|.*\\.)experts\\.1\\.",
      "replacement": "\\1experts.0.",
      "source": "code"
    }
  ],
  "tensor_rules": [
    {
      "pattern": ".*self_attn.*",
      "weights": {
        "code": 0.5,
        "general": 0.5
      }
    },
    {
      "pattern": ".*experts\\.0\\..*",
      "weights": {
        "code": 0.8,
        "general": 0.2
      }
    },
    {
      "pattern": ".*experts\\.1\\..*",
